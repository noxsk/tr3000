{
	"luci-app-wifi-monitor": {
		"description": "Grant access to wifi-monitor config and service",
		"read": {
			"uci": [ "wifi-monitor", "wireless" ],
			"ubus": {
				"network.interface": [ "status" ],
				"network.wireless": [ "status" ],
				"iwinfo": [ "scan", "info" ],
				"service": [ "list" ]
			}
		},
		"write": {
			"uci": [ "wifi-monitor", "wireless" ],
			"luci": [ "setInitAction" ]
		}
	}
}
